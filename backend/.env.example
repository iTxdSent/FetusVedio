APP_NAME=胎儿超声视频流实时解译系统 Demo
API_PREFIX=/api/v1
DATABASE_URL=sqlite:///./data/app.db
STREAM_FPS=30
JPEG_QUALITY=85
CAPTURE_DEVICE_INDEX=0
SYNTHETIC_WIDTH=960
SYNTHETIC_HEIGHT=540
CORS_ALLOW_ORIGINS=["http://127.0.0.1:5173","http://localhost:5173"]
LOCAL_VIDEO_UPLOAD_DIR=./data/uploads
SNAPSHOT_ROOT_DIR=./data/snapshots
MODEL_PROVIDER_BACKEND=mock
AUTO_CAPTURE_CONSECUTIVE_FRAMES=2
AUTO_CAPTURE_COOLDOWN_SEC=5
